# ──────────────────────────────────────────────────────────────────────────────
# credentials.yaml.example
#
# Copy this file to credentials.yaml (which is gitignored) and fill it in.
# Generate password hashes with:  python scripts/hash_password.py
#
# Each user's data_path points to an .xlsx file under data/.
# Only the logged-in user's data file is loaded; one user cannot see another's.
# ──────────────────────────────────────────────────────────────────────────────

credentials:
  usernames:
    jdoe:
      name: Jamie Doe
      email: jdoe@example.edu
      password: $2b$12$REPLACE_WITH_BCRYPT_HASH_FROM_SCRIPT
      # Per-user data file. Path is relative to the app root.
      data_path: data/jdoe_fall2025.xlsx
      # Shown in the page header so the instructor sees which dataset is loaded.
      institution: University of Louisville
      cohort_label: Fall 2025 Gen Chem 1

    mlee:
      name: Morgan Lee
      email: mlee@example.edu
      password: $2b$12$REPLACE_WITH_BCRYPT_HASH_FROM_SCRIPT
      data_path: data/mlee_spring2026.xlsx
      institution: NC State
      cohort_label: Spring 2026 Gen Chem 1

# Cookie keeps the user logged in across browser refreshes.
# The `key` should be a long random string. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# In production, store the key in .streamlit/secrets.toml under [auth] cookie_key
# instead of inlining it here. auth.py reads from secrets first, then falls back
# to the value below.
cookie:
  name: water_dashboard_auth
  key: REPLACE_WITH_RANDOM_STRING
  expiry_days: 30

# Optional: disable self-service password reset / new-user signup since
# we add instructors manually.
preauthorized:
  emails: []
