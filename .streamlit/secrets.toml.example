# ──────────────────────────────────────────────────────────────────────────────
# secrets.toml.example
#
# Local dev:
#   Copy to .streamlit/secrets.toml (gitignored) and fill in cookie_key.
#   You only need credentials_yaml here if you do not want to keep
#   credentials.yaml on disk. Most people just keep credentials.yaml locally
#   and put credentials_yaml only in the deployed app.
#
# Streamlit Community Cloud:
#   Open your app's settings → Secrets, and paste in the same TOML you would
#   use locally. credentials_yaml IS REQUIRED there because the deployed
#   container does not have credentials.yaml on disk.
# ──────────────────────────────────────────────────────────────────────────────

[auth]
# Required. Signs the auth cookie. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
cookie_key = "REPLACE_WITH_RANDOM_TOKEN"

# Required for deployed apps. Paste the entire contents of your
# credentials.yaml between the triple quotes, indented exactly as in the file.
# auth.py will parse this YAML at runtime, so the format must match what
# credentials.yaml.example shows.
credentials_yaml = """
credentials:
  usernames:
    cas:
      name: Cas Koevoets-Beach
      email: cassiekoevoets@gmail.com
      password: '$2b$12$REPLACE_WITH_BCRYPT_HASH'
      data_path: data/cas_demo.xlsx
      institution: University of Louisville
      cohort_label: Demo dataset

cookie:
  name: water_dashboard_auth
  key: not_used_in_production_secrets_overrides
  expiry_days: 30

preauthorized:
  emails: []
"""
